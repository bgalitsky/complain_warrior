        <mxCell id="o2" value="Исход B:&#xa;Ограниченная надежность&#xa;• происхождение не подтверждено полностью&#xa;• «absence of evidence ≠ evidence of absence»&#xa;• требуется усиление контекстом/иными доказательствами" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1020" y="730" width="310" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="o3" value="Исход C:&#xa;Низкая надежность / спорное доказательство&#xa;• признаки манипуляции/синтетики&#xa;• высокий риск целевой антифорензики&#xa;• рекомендовать осторожность/исключение/доп. проверку" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
