          <mxGeometry x="500" y="40" width="300" height="90" as="geometry"/>
        </mxCell>

        <!-- STEP 1 -->
        <mxCell id="step1" value="1. Структурная валидация JPEG&#xa;• Проверка SOI/EOI&#xa;• Анализ маркеров (APP, DQT, DHT, SOF, SOS)&#xa;• Baseline / Progressive&#xa;• Фиксация структуры файла" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="160" width="440" height="130" as="geometry"/>
        </mxCell>

        <!-- STEP 2 -->
        <mxCell id="step2" value="2. Извлечение сегментов DQT&#xa;• Определение Pq и Tq&#xa;• Получение 64 коэффициентов&#xa;• Преобразование zig-zag → 8×8 матрица&#xa;• Сохранение сырого дампа" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="320" width="440" height="150" as="geometry"/>
        </mxCell>

        <!-- STEP 3 -->
        <mxCell id="step3" value="3. Статистический анализ таблиц&#xa;• Среднее / дисперсия&#xa;• Структура частот&#xa;• Сравнение Y и CbCr&#xa;• Определение типа (камера / ПО)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="500" width="440" height="130" as="geometry"/>
        </mxCell>

        <!-- STEP 4 -->
        <mxCell id="step4" value="4. Сопоставление с базой DB_QT&#xa;• Полное совпадение&#xa;• Масштабированное совпадение&#xa;• Расстояние между матрицами&#xa;• Определение вероятного источника" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="660" width="440" height="150" as="geometry"/>
        </mxCell>

        <!-- DECISION 1 -->
        <mxCell id="decision1" value="Совпадает ли таблица&#xa;с известным профилем?" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="850" width="360" height="170" as="geometry"/>
        </mxCell>

        <!-- YES BRANCH -->
        <mxCell id="yes1" value="5A. Проверка согласованности&#xa;• EXIF vs QT&#xa;• Цветовое подвыборивание&#xa;• Разрешение / режим съемки&#xa;• Признаки двойной компрессии" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="1070" width="400" height="170" as="geometry"/>
        </mxCell>

        <!-- NO BRANCH -->
        <mxCell id="no1" value="5B. Таблица нехарактерна&#xa;• Возможна повторная компрессия&#xa;• Использование графического редактора&#xa;• Потенциальная модификация файла" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="1070" width="400" height="170" as="geometry"/>
        </mxCell>

        <!-- DECISION 2 -->
        <mxCell id="decision2" value="Обнаружены несогласованности&#xa;или признаки клонирования?" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="1280" width="360" height="170" as="geometry"/>
        </mxCell>

        <!-- OUTCOME 1 -->
        <mxCell id="out1" value="Исход A&#xa;Таблицы соответствуют заявленному источнику&#xa;Несогласованности не выявлены&#xa;(вероятностный вывод)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
