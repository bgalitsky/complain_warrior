        <!-- OUTCOME 2 -->
        <mxCell id="out2" value="Исход B&#xa;Выявлены признаки обработки / повторной компрессии&#xa;Источник требует уточнения" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="1500" width="420" height="160" as="geometry"/>
        </mxCell>

        <!-- OUTCOME 3 -->
        <mxCell id="out3" value="Исход C&#xa;Высокий риск клонирования структуры JPEG&#xa;QT не доказывает происхождение&#xa;Требуется анализ PRNU / сенсорного шума" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
